# ============================================
# OpenAI Configuration (REQUIRED)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ============================================
# Database Configuration
# ============================================
# Supabase - REST API (works over HTTPS, bypasses firewall)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# Database credentials (for reference)
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your-project
DB_PASSWORD=your-database-password

# Direct PostgreSQL connection URL (URL-encoded password)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# ============================================
# Application Configuration
# ============================================
APP_ENV=development
LOG_LEVEL=INFO

# ============================================
# AI/ML Configuration
# ============================================
# Groq - Fast Reasoning Engine (RECOMMENDED)
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM - Alternative Reasoning Engine (OPTIONAL)
# Get your API key from: https://build.nvidia.com
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key-here

# Reasoning Engine Selection
REASONING_ENGINE=groq  # Options: groq (recommended), nvidia, openai

# Embedding model (recommended: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# LLM model for answer generation
# Options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.0

# ============================================
# Vector Search Configuration
# ============================================
# Number of similar tickets to retrieve
TOP_K_RESULTS=5

# Minimum similarity threshold (0-1)
SIMILARITY_THRESHOLD=0.7

# ============================================
# Data Source Configuration
# ============================================
# Path to Zendesk CSV export file (relative or absolute)
ZENDESK_CSV_PATH=../Zendesk_tix.csv
